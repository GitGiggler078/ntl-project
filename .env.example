# Example environment variables for Night Light NTL Extractor

# Google Earth Engine project ID
GEE_PROJECT_ID=your-gee-project-id-here

# Date filter for the NTL image collection
START_DATE=YYYY-MM-DD
END_DATE=YYYY-MM-DD

# Local file containing a Python module that defines `cities = [...]`
CITIES_FILE=cities.py

# Local cache file for city coordinates
CACHE_FILE=city_coords_cache.json

# Output file for extracted NTL values
OUTPUT_FILE=city_ntl_2026.csv

# Error log filename
ERROR_LOG=error.log

# Geopy configuration
GEOPY_USER_AGENT=ntl_extractor
